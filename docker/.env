# === ZotPrime Docker 环境变量配置 ===
# cp .env.example .env 后修改

# --- 端口配置（不填则用默认值）---
# Zotero API (PHP + Apache)
ZOTERO_API_PORT=8080

# MinIO S3 (API + Console)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- 数据库凭证 ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_USER=zotero
ZOTERO_MYSQL_PASS=zotropass
MYSQL_DATABASE=zotero

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# S3 公开访问地址（客户端连接用）
# 如果通过 Caddy 代理则填 Caddy 域名，否则填 http://<host>:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000

# --- Redis ---
REDIS_PASSWORD=

# --- 管理账号 ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
