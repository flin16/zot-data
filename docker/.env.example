# Zotero Data Server — environment variables
# cp .env.example .env and edit as needed
# (setup.sh does this automatically on first run)

# === Build-time proxy (optional) ===
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# === Database ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=zotero
DB_PASS=zotropass
DB_NAME=zotero
# DB_ROOT_PASS=zotrootpass    # MariaDB root, only used on first init

# === Ports ===
ZOTERO_API_PORT=23231
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
STREAM_PORT=8082

# === MinIO (S3 storage) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Public S3 endpoint for presigned URLs (set to your domain or localhost)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# === Auth ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
# Salt for password hashing in www.users table
AUTH_SALT=dev-salt-change-in-production

# === Stream server (optional) ===
# API_URL=http://127.0.0.1:23231/

# === Redis (optional, needed by stream server) ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
