# Zotero Data Server — Docker 环境变量
# cp .env.example .env 后修改

# === Build-time proxy (optional, uncomment if needed) ===
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# === 数据库 ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=zotero
DB_PASS=zotropass
DB_NAME=zotero
# DB_ROOT_PASS=zotrootpass    # MariaDB root, 仅首次初始化使用

# === 端口 ===
ZOTERO_API_PORT=23231
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
STREAM_PORT=8082

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Caddy: s3.yourserver.com -> :9000 (S3 API)
S3_PUBLIC_ENDPOINT=http://s3.yourserver.com

# === 认证 ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
# 密码 hash 的 salt（www.users 表的密码用 salt + password 生成）
AUTH_SALT=dev-salt-change-in-production

# === Stream server API target ===
# API_URL=http://127.0.0.1:23231/

# === Redis（可选，stream server 需要）===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
