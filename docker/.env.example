# Zotero Data Server — Docker 环境变量
# cp .env.example .env 后修改

# === 数据库（必须配置）===
# macOS/Windows: host.docker.internal
# Linux/服务器: 宿主机 IP 或域名
MYSQL_HOST=host.docker.internal
MYSQL_USER=zotero
ZOTERO_MYSQL_PASS=zotropass
MYSQL_DATABASE=zotero

# === 端口 ===
ZOTERO_API_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Caddy: s3.0und.com -> :9000 (S3 API)
S3_PUBLIC_ENDPOINT=http://s3.0und.com

# === 管理账号 ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass

# === Redis（可选）===
REDIS_PASSWORD=
