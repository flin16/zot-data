# Zotero Data Server — environment overrides
# Copy to .env and edit to match your setup.
#
# All values shown are the defaults — you only need to change what differs.

# ── Domain (used by reverse proxy) ──────────────────────────────────────────
DOMAIN=example.com
API_URL=https://zot.example.com
S3_PUBLIC_ENDPOINT=http://s3.example.com
STREAM_URL=wss://stream.example.com

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=zotero
DB_PASS=zotropass
DB_NAME=zotero

# ── Admin account ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
AUTH_SALT=dev-salt-change-in-production

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Redis (optional, for request limiter + stream server) ─────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Service ports (host) ──────────────────────────────────────────────────────
ZOTERO_API_PORT=8080
STREAM_PORT=8082
